# Normalize all text files to LF in the repo.
# Working-copy line endings follow the OS (autocrlf still applies to checkout).
# This silences the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Binary files Git should never touch.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.pdf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.zip    binary
